import { buildNewIndex } from "./buildNewIndex.js";
import { buildOldIndex } from "./buildOldIndex.js";
import searchIndexNew from "./indexNew.js";
import searchIndexOld from "./indexOld.js";
import { normalize } from "./normalize.js";



export async function buildFlatIndex(lang) {
    const localizedOldIndex = searchIndexOld[lang];
  const oldIndex = await buildOldIndex(localizedOldIndex);
  const newIndex = await buildNewIndex(searchIndexNew, lang);

  return [
    ...oldIndex,
    ...newIndex
  ];
}